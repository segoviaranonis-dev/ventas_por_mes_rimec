# ═══════════════════════════════════════════════════════════════════════════════
# NEXUS CORE - Configuración de Email SMTP
# ═══════════════════════════════════════════════════════════════════════════════
# Copiar este archivo a .env y completar con credenciales reales

# --- ACTIVACIÓN ---
EMAIL_ENABLED=true

# --- SERVIDOR SMTP ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true

# --- CREDENCIALES ---
EMAIL_USERNAME=tu_email@gmail.com
EMAIL_PASSWORD=tu_password_o_app_password

# --- REMITENTE ---
EMAIL_FROM_NAME=NEXUS CORE - RIMEC
EMAIL_FROM_ADDRESS=tu_email@gmail.com

# --- ADMINISTRADORES (separados por comas, sin espacios) ---
EMAIL_ADMIN_ADDRESSES=admin@rimec.com,supervisor@rimec.com

# ═══════════════════════════════════════════════════════════════════════════════
# NOTAS:
# 1. Para Gmail, usar "App Password" en lugar de contraseña normal
# 2. Activar "Permitir aplicaciones menos seguras" si es necesario
# 3. El archivo .env NO debe subirse a Git (ya está en .gitignore)
# ═══════════════════════════════════════════════════════════════════════════════
